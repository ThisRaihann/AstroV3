---
import BaseLayout from '../layouts/BaseLayout.astro';

const socials = [
  { label: 'Tiktok',   href: 'https://tiktok.com/@ngarumisoft',     mono: 'tiktok.com/@ngarumidev' },
  { label: 'Instagram', href: 'https://instagram.com/ngarumisoft',   mono: 'instagram.com/ngarumisoft' },
];

const channels = [
  { icon: '✉', label: 'Email', value: 'ngarumisoft@gmail.com', href: 'mailto:ngarumisoft@gmail.com' },
  { icon: '💬', label: 'WhatsApp', value: 'Chat via WhatsApp', href: 'https://wa.me/6282335999559' },
];
---

<BaseLayout
  title="Kontak — Ngarumi Dev"
  description="Hubungi Ngarumi Dev untuk diskusi proyek, kolaborasi, atau sekadar ngobrol soal web development."
>

<div class="mx-auto w-[min(1160px,100%-2rem)] py-24">

  <div class="mb-20 reveal-section">
    <p class="font-mono text-[0.6rem] tracking-[0.22em] uppercase text-gold mb-5">Kontak</p>
    <h1 class="font-display font-light text-ink leading-[0.95] tracking-[-0.025em]" style="font-size:clamp(3rem,7vw,6rem)">
      Punya ide?<br />
      <em class="not-italic text-gradient-gold">Mari bicara.</em>
    </h1>
  </div>

  <div class="grid lg:grid-cols-[1.2fr_1fr] gap-16 lg:gap-24 reveal-section">

    <div>
      <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="space-y-5" novalidate>
        <input type="hidden" name="access_key" value="19e9ec24-dc2a-43cb-9cc0-1a6f3b0d5ea7">
        <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
        <input type="hidden" name="subject" value="Pesan Baru dari Portfolio Ngarumi Soft">

        <div class="grid sm:grid-cols-2 gap-5">
          <div class="field-wrap">
            <label class="field-label" for="nama">Nama</label>
            <input id="nama" name="nama" type="text" placeholder="Budi Santoso" required class="field-input" />
          </div>
          <div class="field-wrap">
            <label class="field-label" for="email">Email</label>
            <input id="email" name="email" type="email" placeholder="budi@company.com" required class="field-input" />
          </div>
        </div>

        <div class="field-wrap">
          <label class="field-label" for="jenis">Jenis Proyek</label>
          <select id="jenis" name="jenis" class="field-input">
            <option value="">Pilih kategori...</option>
            <option>Company Profile</option>
            <option>ERP</option>
            <option>UI/UX</option>
            <option>E-Commerce</option>
            <option>Lainnya</option>
          </select>
        </div>

        <div class="field-wrap">
          <label class="field-label" for="budget">Estimasi Budget</label>
          <select id="budget" name="budget" class="field-input">
            <option value="">Pilih range...</option>
            <option>Di bawah Rp 5 juta</option>
            <option>Rp 5 – 15 juta</option>
            <option>Rp 15 – 50 juta</option>
            <option>Di atas Rp 50 juta</option>
            <option>Diskusi dulu</option>
          </select>
        </div>

        <div class="field-wrap">
          <label class="field-label" for="pesan">Ceritakan proyek Anda</label>
          <textarea id="pesan" name="pesan" rows="5" placeholder="Apa yang ingin Anda bangun?" required class="field-input resize-none"></textarea>
        </div>

        <button type="submit" id="submit-btn" class="w-full flex items-center justify-center gap-3 px-8 py-4 bg-gold text-bg font-sans text-[0.8rem] font-medium tracking-[0.1em] uppercase rounded-sm transition-all duration-300 hover:bg-gold-light hover:shadow-[0_0_40px_rgba(201,169,110,0.25)]">
          <span id="btn-label">Kirim Pesan</span>
          <svg id="btn-icon" width="13" height="13" viewBox="0 0 14 14" fill="none">
            <path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div id="form-success" class="hidden items-center gap-3 text-sm text-ink-2 p-4 bg-bg-1 border border-bg-2 rounded-lg">
          <span class="w-2 h-2 rounded-full bg-green-400 shrink-0"></span>
          Pesan terkirim! Saya akan balas dalam 24 jam.
        </div>
      </form>
    </div>

    <div class="flex flex-col gap-10">
      <div class="bg-bg-1 border border-bg-2 rounded-xl p-7">
        <div class="flex items-center gap-3 mb-5">
          <span class="w-2 h-2 rounded-full bg-green-400 shadow-[0_0_8px_rgba(74,222,128,0.6)] animate-pulse shrink-0"></span>
          <span class="font-mono text-[0.62rem] tracking-widest uppercase text-ink-2">Available for new projects</span>
        </div>
        <p class="text-sm text-ink-2 leading-relaxed">
          Saat ini kami menerima project baru.
        </p>
      </div>

      <div class="space-y-3">
        {channels.map(c => (
          <a href={c.href} class="group flex items-center gap-4 p-4 bg-bg-1 border border-bg-2 rounded-lg hover:border-gold/30 transition-all duration-200">
            <span class="text-lg">{c.icon}</span>
            <div>
              <p class="text-[0.72rem] font-mono tracking-widest uppercase text-ink-3 mb-0.5">{c.label}</p>
              <p class="text-sm text-ink-2 group-hover:text-gold transition-colors">{c.value}</p>
            </div>
          </a>
        ))}
      </div>

      <div class="space-y-2.5">
        {socials.map(s => (
          <a href={s.href} class="group flex items-baseline justify-between py-2 border-b border-bg-2 hover:border-gold/20 transition-colors">
            <span class="text-sm text-ink-2 group-hover:text-gold transition-colors">{s.label}</span>
            <span class="font-mono text-[0.62rem] text-ink-3 lowercase">{s.mono}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</div>

</BaseLayout>

<style>
  .reveal-section { opacity:0; transform:translateY(32px); transition:opacity 1s ease, transform 1s ease; }
  .reveal-section.in-view { opacity:1; transform:translateY(0); }
  .text-gradient-gold { background: linear-gradient(to right, #bf953f, #fcf6ba, #b38728); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

  .field-wrap { display:flex; flex-direction:column; gap:0.5rem; }
  .field-label { font-family: monospace; font-size: 0.62rem; letter-spacing: 0.14em; text-transform: uppercase; color: #888; }
  .field-input { width: 100%; background: #0c0c0c; border: 1px solid #222; color: #fff; font-size: 0.9rem; padding: 0.8rem 1rem; border-radius: 4px; outline: none; }
  .field-input:focus { border-color: #bf953f; background: #111; }
</style>

<script>
  // Observer
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in-view'); obs.unobserve(e.target); } });
  }, { threshold: 0.06 });
  document.querySelectorAll('.reveal-section').forEach(el => obs.observe(el));

  // Form handling (Web3Forms Fetch)
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const label = document.getElementById('btn-label') as HTMLElement;
  const icon = document.getElementById('btn-icon') as HTMLElement;
  const success = document.getElementById('form-success') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    label.textContent = 'Mengirim...';
    icon.style.display = 'none';

    const formData = new FormData(form);
    try {
      const res = await fetch(form.action, { method: 'POST', body: formData });
      if (res.ok) {
        form.reset();
        btn.style.display = 'none';
        success.classList.remove('hidden');
        success.classList.add('flex');
      }
    } catch (err) {
      label.textContent = 'Gagal Mengirim';
      btn.disabled = false;
    }
  });
</script>