---
import BaseLayout from '../layouts/BaseLayout.astro';

// SEO Data
const seoData = {
  title: "Proyek & Portfolio Sistem Manajemen — Ngarumi Soft",
  description: "Eksplorasi karya digital Ngarumi Soft: dari sistem ERP NUKlerr hingga teknologi maritim.",
  image: "/images/og-projects.jpg"
};

const projects = [
  {
    label: '01', title: 'NUKLERR ERP System', category: 'Management System · 2025',
    desc: 'Sistem manajemen stok, POS, dan Laporan Keuangan terintegrasi. Membantu sinkronisasi data multigudang secara real-time dengan efisiensi alur kerja maksimal.',
    tech: ['Laravel', 'Livewire', 'MySQL', 'Tailwind','SweetAlert2'],
    link: '#', featured: true,
  },
  {
    label: '02', title: 'R Project Event', category: 'Portfolio Tech · 2025',
    desc: 'Platform kurasi karya digital yang dirancang untuk mengelola dan memamerkan arsip proyek secara sistematis, meningkatkan nilai jual visual dan kredibilitas profesional di hadapan klien.',
    tech: ['CodeIgniter 3', 'Bootstrap', 'MySQL'],
    link: 'https://rprojectevent.com/', featured: false,
  },
  {
    label: '03', title: 'UMKM Kelurahan Wonorejo', category: 'Local Economy · 2025',
    desc: 'Sistem informasi geografis dan inventarisasi UMKM terpusat untuk pendataan profil usaha, katalog produk unggulan, dan pemetaan lokasi pelaku usaha di Kelurahan Rungkut.',
    tech: ['CodeIgniter 3', 'Tailwind', 'MySQL'],
    link: 'https://umkmwonorejorungkut.netlify.app/', featured: false,
  },
  {
    label: '04', title: 'RKOMNIBUS', category: 'Academic Competitions · 2025',
    desc: 'Sistem pendaftaran terpadu untuk kompetisi akademik Radar Kediri yang dirancang untuk menangani ribuan registrasi peserta secara sistematis dengan validasi data yang akurat.',
    tech: ['Laravel', 'MySQL', 'Tailwind'],
    link: 'https://rkomnibus.com/', featured: false,
  },
  {
    label: '05', title: 'FAWZIE ELCRAFT', category: 'Creative E-Catalog · 2025',
    desc: 'Showcase digital untuk UMKM kreatif yang memamerkan produk buket bunga dan handicraft dengan navigasi katalog yang intuitif dan visual yang menarik.',
    tech: ['HTML', 'CSS', 'JavaScript'],
    link: 'https://fawziaelcraft.netlify.app/', featured: false,
  },
  {
    label: '06', title: 'OTAK - OTAK CRISPY MBAK CU', category: 'F&B Digital Catalog · 2026',
    desc: 'Sistem katalog menu online yang memudahkan UMKM kuliner dalam mempublikasikan varian rasa dan detail produk secara terorganisir serta mudah diakses melalui perangkat mobile.',
    tech: ['HTML', 'CSS', 'JavaScript'],
    link: 'https://otakotakcrispymbakcu.netlify.app/', featured: false,
  },
];

const gallery = [
  { url: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=2070', alt: 'Dashboard' },
  { url: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?q=80&w=2015', alt: 'ERP Database' },
  { url: 'https://images.unsplash.com/photo-1507238691740-187a5b1d37b8?q=80&w=1955', alt: 'Event Visuals' },
  { url: 'https://images.unsplash.com/photo-1555066931-4365d14bab8c?q=80&w=2070', alt: 'Code Architecture' },
  { url: 'https://images.unsplash.com/photo-1551033406-611cf9a28f67?q=80&w=1974', alt: 'Backend Logic' },
  { url: 'https://images.unsplash.com/photo-1531403009284-440f080d1e12?q=80&w=2070', alt: 'UI Design System' },
  { url: 'https://images.unsplash.com/photo-1517694712202-14dd9538aa97?q=80&w=2070', alt: 'Laptop Setup' },
];

const featured = projects.filter(p => p.featured);
const rest = projects.filter(p => !p.featured);
---

<BaseLayout {...seoData}>
  
  <script type="application/ld+json" slot="head">
    {
      "@context": "https://schema.org",
      "@type": "CollectionPage",
      "name": "Portfolio Ngarumi Soft",
      "description": "Daftar proyek pengembangan sistem informasi oleh Ngarumi Soft.",
      "publisher": { "@type": "Organization", "name": "Ngarumi Soft" }
    }
  </script>

  <main class="mx-auto w-[min(1200px,100%-2rem)] py-24">

    <header class="mb-24 reveal-section">
      <p class="font-mono text-[0.6rem] tracking-[0.3em] uppercase text-gold mb-6">Portfolio Archive</p>
      <div class="flex flex-col lg:flex-row lg:items-end justify-between gap-12">
        <h1 class="font-display font-light text-ink leading-[1] tracking-tight" style="font-size:clamp(3rem,8vw,6rem)">
          Karya Pilihan<br />
          <span class="text-gradient-gold italic font-serif">Ngarumi</span> Soft.
        </h1>
        <p class="text-ink-2 font-light leading-relaxed max-w-sm text-[1rem]">
          Membangun infrastruktur digital yang efisien, skalabel, dan berdampak bagi mitra bisnis kami.
        </p>
      </div>
    </header>

    <section class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-32 reveal-section">
      {featured.map(p => (
        <a href={p.link} class="group relative bg-bg-1/50 border border-bg-2 lg:col-span-2 flex flex-col justify-between p-12 min-h-[420px] rounded-3xl overflow-hidden hover:border-gold/30 transition-all duration-700 shadow-2xl shadow-black/20">
          <span aria-hidden="true" class="pointer-events-none absolute -right-4 -bottom-8 font-display text-[15rem] font-light leading-none text-bg-2 select-none group-hover:text-bg-3 transition-colors duration-700 opacity-50">{p.label}</span>
          
          <div class="relative z-10 flex items-center justify-between">
            <span class="font-mono text-[0.65rem] tracking-[0.2em] uppercase text-gold/70">{p.category}</span>
            <div class="w-10 h-10 rounded-full border border-bg-3 flex items-center justify-center group-hover:bg-gold group-hover:text-bg transition-all">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M7 17L17 7M17 7H7M17 7V17" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>

          <div class="relative z-10">
            <h2 class="font-display font-light text-4xl text-ink mb-4 group-hover:text-gold transition-colors">{p.title}</h2>
            <p class="text-[1.05rem] text-ink-2 font-light leading-relaxed max-w-lg mb-8">{p.desc}</p>
            <div class="flex flex-wrap gap-2">
              {p.tech.map(t => <span class="font-mono text-[0.6rem] tracking-wider text-ink-3 border border-bg-3 px-3 py-1 rounded-sm bg-bg-1">{t}</span>)}
            </div>
          </div>
        </a>
      ))}

      <div class="bg-bg-1/30 border border-dashed border-bg-3 flex flex-col justify-between p-12 rounded-3xl">
        <div>
          <p class="font-mono text-[0.6rem] tracking-widest uppercase text-ink-3 mb-8">Completed Works</p>
          <p class="font-display font-light text-gold leading-none mb-4" style="font-size:5.5rem">5<span class="text-3xl">+</span></p>
          <p class="text-sm text-ink-2 font-light">Sistem kustom yang telah dideploy untuk berbagai sektor industri.</p>
        </div>
        <div class="pt-8 border-t border-bg-2 space-y-4">
           {[['ERP Systems', '04'], ['LMS Platform', '03'], ['Ship Nav', '01']].map(([cat, val]) => (
             <div class="flex justify-between text-[0.7rem] font-mono">
                <span class="text-ink-3 uppercase">{cat}</span>
                <span class="text-gold">{val}</span>
             </div>
           ))}
        </div>
      </div>
    </section>

    

    <section class="reveal-section mb-40">
      <div class="flex items-center gap-6 mb-12">
        <h2 class="font-mono text-[0.7rem] tracking-[0.3em] uppercase text-gold">Other Projects</h2>
        <div class="h-px bg-gradient-to-r from-bg-3 to-transparent flex-1" aria-hidden="true"></div>
      </div>

      <div class="divide-y divide-bg-2 border-y border-bg-2">
        {rest.map(p => (
          <article class="group">
            <a href={p.link} class="grid grid-cols-1 md:grid-cols-[100px_1fr_auto] items-center gap-6 py-14 hover:bg-bg-1/40 transition-all duration-500 px-4 md:px-8">
              <span class="font-display text-4xl font-light text-bg-3 group-hover:text-gold/40 transition-colors shrink-0 select-none">{p.label}</span>
              <div class="flex-1">
                <p class="font-mono text-[0.6rem] tracking-[0.2em] uppercase text-ink-3 mb-2">{p.category}</p>
                <h3 class="font-display font-light text-2xl text-ink mb-2 group-hover:text-gold transition-colors">{p.title}</h3>
                <p class="text-[0.95rem] text-ink-2 font-light leading-relaxed max-w-xl">{p.desc}</p>
              </div>
              <div class="flex flex-wrap gap-2 md:justify-end">
                {p.tech.map(t => <span class="font-mono text-[0.55rem] tracking-wider text-ink-3 border border-bg-3 px-2 py-1 rounded-sm">{t}</span>)}
              </div>
            </a>
          </article>
        ))}
      </div>
    </section>

    <section class="mb-40 reveal-section overflow-hidden">
      <div class="flex items-center gap-6 mb-12">
        <h2 class="font-mono text-[0.7rem] tracking-[0.3em] uppercase text-gold">Behind the Interface</h2>
        <div class="h-px bg-gradient-to-r from-bg-3 to-transparent flex-1" aria-hidden="true"></div>
      </div>

      <div class="relative flex overflow-x-hidden group">
        <div class="flex animate-marquee whitespace-nowrap gap-4 py-4">
          {[...gallery, ...gallery].map((img) => (
            <div class="relative w-48 h-32 md:w-64 md:h-44 flex-shrink-0 overflow-hidden rounded-2xl bg-bg-2 border border-bg-3/30">
              <img 
                src={img.url} 
                alt={img.alt}
                loading="lazy"
                class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 hover:scale-110"
              />
              <div class="absolute inset-0 bg-black/40 opacity-0 hover:opacity-100 transition-opacity flex items-center justify-center">
                 <span class="text-[0.5rem] text-white font-mono uppercase tracking-widest">{img.alt}</span>
              </div>
            </div>
          ))}
        </div>
        
        <div class="absolute top-0 flex animate-marquee2 whitespace-nowrap gap-4 py-4">
          {[...gallery, ...gallery].map((img) => (
            <div class="relative w-48 h-32 md:w-64 md:h-44 flex-shrink-0 overflow-hidden rounded-2xl bg-bg-2 border border-bg-3/30">
              <img 
                src={img.url} 
                alt={img.alt}
                loading="lazy"
                class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 hover:scale-110"
              />
               <div class="absolute inset-0 bg-black/40 opacity-0 hover:opacity-100 transition-opacity flex items-center justify-center">
                 <span class="text-[0.5rem] text-white font-mono uppercase tracking-widest">{img.alt}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="reveal-section text-center py-20 border-t border-bg-2">
      <h2 class="font-display font-light text-3xl sm:text-5xl text-ink mb-10 leading-tight">
        Siap Mewujudkan <br/>
        <span class="text-gradient-gold italic">Sistem Impian Anda?</span>
      </h2>
      <a href="/kontak" class="inline-flex items-center gap-4 px-12 py-5 bg-gold text-bg font-sans text-[0.8rem] font-bold tracking-[0.15em] uppercase rounded-sm transition-all duration-300 hover:bg-gold-light hover:shadow-[0_0_50px_rgba(212,175,55,0.35)]">
        Mulai Konsultasi
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </section>

  </main>
</BaseLayout>

<style>
  /* Reveal Animation */
  .reveal-section { 
    opacity: 0; 
    transform: translateY(32px); 
    transition: all 1.2s cubic-bezier(0.22, 1, 0.36, 1); 
  }
  .reveal-section.in-view { 
    opacity: 1; 
    transform: translateY(0); 
  }

  /* Gold Gradient Text */
  .text-gradient-gold {
    background: linear-gradient(to right, #bf953f, #fcf6ba, #b38728);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline-block;
  }

  /* Marquee Animation */
  .animate-marquee {
    animation: marquee 50s linear infinite;
  }

  .animate-marquee2 {
    animation: marquee2 50s linear infinite;
  }

  /* Pause marquee on hover */
  .group:hover .animate-marquee,
  .group:hover .animate-marquee2 {
    animation-play-state: paused;
  }

  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-100%); }
  }

  @keyframes marquee2 {
    0% { transform: translateX(100%); }
    100% { transform: translateX(0%); }
  }

  /* Custom Scrollbar for better UX if needed */
  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: #0a0a0a; }
  ::-webkit-scrollbar-thumb { background: #bf953f; border-radius: 10px; }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { 
      if (e.isIntersecting) { 
        e.target.classList.add('in-view'); 
        obs.unobserve(e.target); 
      } 
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

  document.querySelectorAll('.reveal-section').forEach(el => obs.observe(el));
</script>