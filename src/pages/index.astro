---
import BaseLayout from '../layouts/BaseLayout.astro';

const stats = [
  { value: 5,  suffix: '+',  label: 'Proyek Selesai' },
  { value: 1,   suffix: 'yr', label: 'Pengalaman' },
  { value: 98,  suffix: '',   label: 'Skor Lighthouse' },
  { value: 99, suffix: '%',  label: 'Client Puas' },
];

const clientLogos = [
  { src: '/logos/event.webp', alt: 'Radar Kediri' },
  { src: '/logos/nukleer.webp', alt: 'PT Persada Nawa Kartika' },
  { src: '/logos/radar.webp', alt: 'Jawa Pos Radar Kediri' },
  { src: '/logos/mbakcu.webp', alt: 'Otak - Otak Crispy Mbak Cu' },
  { src: '/logos/sby.webp', alt: 'Kelurahan Wonorejo Rungkut' },
];
---

<BaseLayout>

<div id="cursor" class="fixed top-0 left-0 z-[9998] pointer-events-none mix-blend-difference hidden lg:block">
  <div id="cursor-dot"  class="absolute w-2 h-2 -translate-x-1/2 -translate-y-1/2 rounded-full bg-white"></div>
  <div id="cursor-ring" class="absolute w-8 h-8 -translate-x-1/2 -translate-y-1/2 rounded-full border border-white/50 transition-[width,height,border-color] duration-500 ease-out-expo"></div>
</div>

<section id="hero" class="relative min-h-[100svh] flex items-center overflow-hidden bg-bg">
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 overflow-hidden">
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>
  </div>

  <div aria-hidden="true" class="pointer-events-none absolute inset-0"
    style="background-image:linear-gradient(rgba(201,169,110,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(201,169,110,0.04) 1px,transparent 1px);background-size:60px 60px">
  </div>

  <div id="scanline" aria-hidden="true" class="pointer-events-none absolute left-0 right-0 h-px bg-gradient-to-r from-transparent via-gold/25 to-transparent z-20"></div>

  <div class="mx-auto w-[min(1160px,100%-2rem)] relative z-10 py-24">
    <div class="hero-reveal flex items-center gap-4 mb-10">
      <span class="relative flex h-2 w-2 shrink-0">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-gold opacity-60"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-gold"></span>
      </span>
      <span class="font-mono text-[0.65rem] tracking-[0.25em] uppercase text-gold/80">
        Fullstack Developer · Indonesia · Open to Projects
      </span>
    </div>

    <h1 class="hero-reveal font-display font-light text-ink leading-[0.92] tracking-[-0.03em] mb-10" style="font-size:clamp(3.5rem,10vw,8.5rem)">
      Crafting<br />
      <em class="not-italic text-gradient-gold">Digital</em><br />
      Experiences
    </h1>

    <div class="hero-reveal flex flex-col sm:flex-row sm:items-end gap-8 mt-4">
      <p class="text-ink-2 font-light leading-[1.9] max-w-md text-[1.05rem]">
        Halo, Kami <strong class="text-ink font-normal">Ngarumi</strong> membangun produk web yang
        elegan, cepat, dan memberi dampak nyata. Dari konsep hingga deployment.
      </p>

      <div class="flex flex-col gap-3 sm:border-l sm:border-bg-3 sm:pl-8 shrink-0">
        <a href="/proyek" class="magnetic group inline-flex items-center gap-3 px-7 py-4 bg-gold text-bg font-sans text-[0.8rem] font-medium tracking-[0.1em] uppercase rounded-sm transition-all duration-300 hover:bg-gold-light hover:shadow-[0_0_50px_rgba(201,169,110,0.3)]">
          Lihat Proyek
          <svg class="transition-transform group-hover:translate-x-1" width="13" height="13" viewBox="0 0 14 14" fill="none">
            <path d="M3 11L11 3M11 3H5M11 3V9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/kontak" class="magnetic group inline-flex items-center gap-3 px-7 py-4 border border-bg-3 text-ink-2 text-[0.8rem] tracking-[0.08em] uppercase rounded-sm transition-all duration-300 hover:border-gold/40 hover:text-gold">
          Diskusi Proyek
        </a>
      </div>
    </div>

    <div class="hero-reveal grid grid-cols-2 sm:grid-cols-4 gap-px mt-24 rounded-lg overflow-hidden border border-bg-2 bg-bg-2">
      {stats.map(s => (
        <div class="group bg-bg flex flex-col gap-1 px-6 py-7 hover:bg-bg-1 transition-colors duration-300 cursor-default">
          <p class="font-display text-[2.6rem] font-light leading-none text-gold">
            <span class="counter" data-target={s.value}>{s.value}</span>{s.suffix}
          </p>
          <p class="font-mono text-[0.6rem] tracking-[0.18em] uppercase text-ink-3 mt-1">{s.label}</p>
        </div>
      ))}
    </div>
  </div>

  <div aria-hidden="true" class="pointer-events-none hidden lg:block absolute bottom-24 right-[-3.5rem] rotate-90 origin-right font-mono text-[0.55rem] tracking-[0.4em] uppercase text-ink-3/25 whitespace-nowrap select-none">
    ngarumi.dev · fullstack engineer · indonesia
  </div>

  <div aria-hidden="true" class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 opacity-25">
    <span class="font-mono text-[0.52rem] tracking-[0.25em] uppercase text-ink-3">Scroll</span>
    <div class="w-px h-12 relative overflow-hidden bg-bg-3">
      <div class="absolute inset-0 bg-gold" style="animation:slideDown 1.8s ease-in-out infinite"></div>
    </div>
  </div>
</section>

<section class="py-12 bg-bg overflow-hidden reveal-section">
  <div class="mx-auto w-[min(1160px,100%-2rem)]">
    <div class="relative py-14 px-8 border border-bg-2 rounded-2xl bg-bg-1/30 overflow-hidden group/marquee">
      
      <div class="pointer-events-none absolute inset-y-0 left-0 w-24 z-10 bg-gradient-to-r from-bg-1/80 to-transparent"></div>
      <div class="pointer-events-none absolute inset-y-0 right-0 w-24 z-10 bg-gradient-to-l from-bg-1/80 to-transparent"></div>

      <div class="flex overflow-hidden select-none">
        <div class="flex flex-nowrap shrink-0 gap-24 items-center animate-marquee-img">
          {[...clientLogos, ...clientLogos].map(logo => (
            <div class="flex flex-col items-center gap-4 shrink-0 min-w-[140px] group/item">
              <div class="h-10 flex items-center justify-center">
                <img 
                  src={logo.src} 
                  alt={logo.alt} 
                  class:list={[
                    /* Balik ke Abu-Abu: grayscale + invert + opacity-20 */
                    "h-full w-auto object-contain grayscale invert opacity-20 group-hover/item:grayscale-0 group-hover/item:invert-0 group-hover/item:opacity-100 transition-all duration-700 cursor-pointer"
                  ]} 
                />
              </div>
              <p class="font-mono text-[9px] tracking-[0.25em] uppercase text-white/70 transition-colors group-hover/item:text-gold group-hover/item:opacity-100">
  {logo.alt}
</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-32 reveal-section bg-bg">
  <div class="mx-auto w-[min(1160px,100%-2rem)]">
    <div class="flex justify-between items-end mb-16">
      <div>
        <h2 class="font-display text-4xl text-ink mb-4">Karya Pilihan</h2>
        <p class="text-ink-3 font-mono text-xs uppercase tracking-widest">01 — Proyek Terbaru</p>
      </div>
      <a href="/proyek" class="text-gold text-xs font-mono uppercase tracking-widest hover:pr-4 transition-all">Lihat Semua →</a>
    </div>

    <div class="grid md:grid-cols-2 gap-12">
      <div class="group cursor-pointer">
        <div class="relative aspect-[16/10] overflow-hidden bg-bg-2 rounded-sm mb-6">
          <div class="absolute inset-0 bg-gold/10 group-hover:bg-transparent transition-colors duration-500 z-10"></div>
          <img src="nuklerr.jpg" 
               alt="Project" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
        </div>
        <h3 class="font-display text-2xl text-ink mb-2">Manajemen Inventaris, Kasir, dan Laporan Keuangan</h3>
        <p class="text-ink-3 text-sm leading-relaxed max-w-sm">Membangun platform ERP eksklusif dengan performa maksimal dan transisi halus.</p>
      </div>

      <div class="group cursor-pointer md:mt-24">
        <div class="relative aspect-[16/10] overflow-hidden bg-bg-2 rounded-sm mb-6">
          <div class="absolute inset-0 bg-gold/10 group-hover:bg-transparent transition-colors duration-500 z-10"></div>
          <img src="event.webp" 
               alt="Project" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
        </div>
          <h3 class="font-display text-2xl text-ink mb-2">R Project Dashboard</h3>
          <p class="text-ink-3 text-sm leading-relaxed max-w-sm">Sistem manajemen konten dan analisis data untuk mendukung ekosistem event organizer yang dinamis dan terukur.</p>
      </div>
    </div>
  </div>
</section>

<section class="py-24 border-t border-bg-2 reveal-section bg-bg">
  <div class="mx-auto w-[min(1160px,100%-2rem)]">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-px bg-bg-2 rounded-xl overflow-hidden border border-bg-2">
      {[
        { href: '/tentang',  label: 'Tentang',  desc: 'Siapa saya & stack yang saya pakai',         icon: '◎' },
        { href: '/layanan',  label: 'Layanan',  desc: 'Apa yang bisa saya bantu untuk Anda',         icon: '◈' },
        { href: '/proyek',   label: 'Proyek',   desc: 'Portofolio & karya pilihan',                  icon: '◉' },
        { href: '/kontak',   label: 'Kontak',   desc: 'Diskusi proyek & kolaborasi',                 icon: '⬡' },
      ].map(l => (
        <a href={l.href} class="group bg-bg flex flex-col gap-4 p-8 hover:bg-bg-1 transition-all duration-300">
          <span class="text-xl text-gold/50 group-hover:text-gold transition-colors">{l.icon}</span>
          <div>
            <p class="font-display font-light text-xl text-ink mb-1 group-hover:text-gradient-gold transition-all">{l.label}</p>
            <p class="text-sm text-ink-3 leading-relaxed">{l.desc}</p>
          </div>
          <svg class="w-4 h-4 text-bg-3 group-hover:text-gold group-hover:translate-x-1 group-hover:-translate-y-1 transition-all mt-auto" viewBox="0 0 18 18" fill="none">
            <path d="M4 14L14 4M14 4H7M14 4V11" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      ))}
    </div>
  </div>
</section>

</BaseLayout>

<style is:global>
  /* Base Orbs */
  .orb { position:absolute; border-radius:50%; filter:blur(80px); pointer-events:none; z-index: 1; }
  .orb-1 { width:700px; height:700px; opacity:0.1; background:radial-gradient(circle,#c9a96e 0%,transparent 70%); top:-20%; left:-15%; animation:drift1 20s ease-in-out infinite; }
  .orb-2 { width:500px; height:500px; opacity:0.09; background:radial-gradient(circle,#a07840 0%,transparent 70%); top:25%; right:-15%; animation:drift2 25s ease-in-out infinite; }
  .orb-3 { width:350px; height:350px; opacity:0.06; background:radial-gradient(circle,#c9a96e 0%,transparent 70%); bottom:8%; left:38%; animation:drift3 17s ease-in-out infinite; }

  /* Keyframes */
  @keyframes drift1 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(70px,50px) scale(1.12)} }
  @keyframes drift2 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(-55px,75px) scale(1.08)} }
  @keyframes drift3 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(35px,-45px) scale(1.18)} }
  @keyframes scanlineMove { 0%{top:-2px;opacity:0} 8%{opacity:1} 92%{opacity:1} 100%{top:100%;opacity:0} }
  @keyframes slideDown { 0%{transform:translateY(-100%)} 100%{transform:translateY(200%)} }
  @keyframes marquee-img { from { transform: translateX(0); } to { transform: translateX(-50%); } }

  /* Animation Classes */
  #scanline { animation:scanlineMove 9s ease-in-out infinite; }
  .animate-marquee-img { animation: marquee-img 40s linear infinite; width: max-content; }
  .group\/marquee:hover .animate-marquee-img { animation-play-state: paused; }

  /* Reveals */
  .hero-reveal { opacity:0; transform:translateY(28px); }
  .reveal-section { opacity:0; transform:translateY(36px); transition:opacity 1.1s cubic-bezier(0.22,1,0.36,1),transform 1.1s cubic-bezier(0.22,1,0.36,1); }
  .reveal-section.in-view { opacity:1 !important; transform:translateY(0) !important; }
</style>

<script>
  // Script tetap sama...
  const dot  = document.getElementById('cursor-dot') as HTMLElement;
  const ring = document.getElementById('cursor-ring') as HTMLElement;
  if (dot && ring) {
    let mx=0,my=0,rx=0,ry=0;
    document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;dot.style.cssText=`left:${mx}px;top:${my}px`});
    (function lerp(){rx+=(mx-rx)*0.09;ry+=(my-ry)*0.09;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(lerp)})();
    document.querySelectorAll('a,button').forEach(el=>{
      el.addEventListener('mouseenter',()=>{ring.style.width='52px';ring.style.height='52px';ring.style.borderColor='rgba(201,169,110,0.75)';});
      el.addEventListener('mouseleave',()=>{ring.style.width='32px';ring.style.height='32px';ring.style.borderColor='rgba(255,255,255,0.5)';});
    });
  }
  document.querySelectorAll<HTMLElement>('.hero-reveal').forEach((el,i)=>{
    setTimeout(()=>{el.style.transition='opacity 1s cubic-bezier(0.22,1,0.36,1),transform 1s cubic-bezier(0.22,1,0.36,1)';el.style.opacity='1';el.style.transform='translateY(0)';},100+i*160);
  });
  const obs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in-view');obs.unobserve(e.target);}});},{threshold:0.07});
  document.querySelectorAll('.reveal-section').forEach(el=>obs.observe(el));
  const cntObs=new IntersectionObserver(entries=>{entries.forEach(e=>{if(!e.isIntersecting)return;e.target.querySelectorAll<HTMLElement>('.counter').forEach(el=>{const target=parseInt(el.dataset.target??'0');const start=performance.now();const tick=(now:number)=>{const p=Math.min((now-start)/1800,1);el.textContent=Math.round((1-Math.pow(1-p,4))*target).toString();if(p<1)requestAnimationFrame(tick);};requestAnimationFrame(tick);});cntObs.unobserve(e.target);});},{threshold:0.4});
  document.querySelectorAll('#hero').forEach(el=>cntObs.observe(el));
  document.querySelectorAll<HTMLElement>('.magnetic').forEach(btn=>{
    btn.addEventListener('mousemove',e=>{const r=btn.getBoundingClientRect();btn.style.transform=`translate(${(e.clientX-r.left-r.width/2)*0.16}px,${(e.clientY-r.top-r.height/2)*0.16}px)`;btn.style.transition='transform 0.1s';});
    btn.addEventListener('mouseleave',()=>{btn.style.transform='';btn.style.transition='transform 0.5s cubic-bezier(0.22,1,0.36,1)';});
  });
</script>