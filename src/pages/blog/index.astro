---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Mengambil data dari Content Collections
const allPosts = await getCollection('blog');

// Mapping & Sorting data
const sortedPosts = allPosts
  .map(post => ({
    slug: post.slug,
    title: post.data.title ?? 'Tanpa Judul',
    description: post.data.description ?? '',
    pubDate: post.data.pubDate,
    tags: post.data.tags ?? [],
    image: post.data.image?.url ?? null,
  }))
  .sort((a, b) => new Date(b.pubDate).getTime() - new Date(a.pubDate).getTime());

// Pisahkan post: 1 Utama (Featured), 2-4 Grid, Sisanya masuk "Berita Lain"
const featuredPost = sortedPosts[0];
const gridPosts = sortedPosts.slice(1, 4);
const otherPosts = sortedPosts.slice(4);

// Ambil semua tag unik
const allTags = [...new Set(sortedPosts.flatMap(p => p.tags))].sort();
---

<BaseLayout
  title="Blog — Ngarumi Dev"
  description="Artikel tentang web development, arsitektur software, dan tips praktis dari pengalaman membangun produk digital."
>
  <main class="mx-auto w-[min(1160px,100%-3rem)] py-20">

    <header class="mb-16 max-w-2xl reveal-section">
      <p class="font-mono text-[0.68rem] tracking-[0.18em] uppercase text-gold mb-5">Journal & Insights</p>
      <h1 class="font-display font-light text-5xl md:text-6xl text-ink mb-5 leading-tight">
        Tulisan & <span class="text-gradient-gold italic">Pemikiran</span>
      </h1>
      <p class="text-ink-2 font-light leading-relaxed text-lg">
        Catatan perjalanan di dunia engineering — dari pola arsitektur hingga strategi membangun software yang berdampak.
      </p>
    </header>

    {sortedPosts.length === 0 ? (
      <div class="text-center py-24 border border-dashed border-bg-3 rounded-3xl">
        <p class="font-display text-3xl font-light text-ink-3 mb-3">Belum ada artikel</p>
        <p class="text-sm text-ink-3 font-mono tracking-wide uppercase">Segera hadir — Stay Tuned</p>
      </div>
    ) : (
      <>
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-24">
          
          {featuredPost && (
            <div class="lg:col-span-2 reveal-section">
              <a href={`/blog/${featuredPost.slug}`} class="group flex flex-col h-full bg-bg-1 border border-bg-2 rounded-3xl overflow-hidden hover:border-gold/30 transition-all duration-500">
                <div class="aspect-[16/9] overflow-hidden bg-bg-2">
                  <img src={featuredPost.image} alt={featuredPost.title} class="w-full h-full object-cover  group-hover:scale-105 transition-all duration-700" />
                </div>
                <div class="p-8 md:p-12 flex flex-col flex-1">
                  <div class="flex gap-2 mb-4">
                    {featuredPost.tags.map(tag => <span class="font-mono text-[0.6rem] text-gold uppercase tracking-tighter border border-gold/20 px-2 py-0.5 rounded-sm">{tag}</span>)}
                  </div>
                  <h2 class="font-display font-light text-3xl md:text-4xl text-ink mb-4 group-hover:text-gold transition-colors">{featuredPost.title}</h2>
                  <p class="text-ink-2 font-light leading-relaxed mb-8 line-clamp-3 text-lg">{featuredPost.description}</p>
                  <div class="mt-auto pt-6 border-t border-bg-2 flex justify-between items-center text-ink-3 font-mono text-[0.65rem]">
                    <time>{new Date(featuredPost.pubDate).toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
                    <span class="text-gold uppercase tracking-widest group-hover:translate-x-2 transition-transform">Baca Selengkapnya →</span>
                  </div>
                </div>
              </a>
            </div>
          )}

          <div class="space-y-8">
            {gridPosts.map(post => (
              <a href={`/blog/${post.slug}`} class="group block reveal-section">
                <div class="relative overflow-hidden rounded-2xl aspect-video mb-4 border border-bg-2">
                   <img src={post.image} alt={post.title} class="w-full h-full object-cover transition-all duration-500" />
                </div>
                <h3 class="font-display font-light text-xl text-ink group-hover:text-gold transition-colors leading-tight mb-2">{post.title}</h3>
                <p class="text-ink-3 font-mono text-[0.6rem] uppercase tracking-wide">{new Date(post.pubDate).toLocaleDateString('id-ID', { month: 'short', day: 'numeric', year: 'numeric' })}</p>
              </a>
            ))}
          </div>
        </div>

        {otherPosts.length > 0 && (
          <section class="reveal-section border-t border-bg-2 pt-16">
            <h2 class="font-mono text-[0.7rem] tracking-[0.3em] uppercase text-gold mb-12">Arsip Berita Lain</h2>
            <div class="divide-y divide-bg-2">
              {otherPosts.map(post => (
                <a href={`/blog/${post.slug}`} class="group grid grid-cols-1 md:grid-cols-[1fr_auto] items-center py-8 hover:px-4 transition-all duration-300">
                  <div class="flex flex-col gap-2">
                    <p class="font-mono text-[0.6rem] text-ink-3 uppercase tracking-widest">
                       {new Date(post.pubDate).toLocaleDateString('id-ID', { month: 'long', year: 'numeric' })} — {post.tags[0]}
                    </p>
                    <h3 class="font-display font-light text-2xl text-ink group-hover:text-gold transition-colors">{post.title}</h3>
                  </div>
                  <div class="hidden md:block">
                     <div class="w-10 h-10 rounded-full border border-bg-3 flex items-center justify-center group-hover:bg-gold group-hover:text-bg transition-all">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                          <path d="M7 17L17 7M17 7H7M17 7V17" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                     </div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}
      </>
    )}
  </main>
</BaseLayout>

<style>
  .text-gradient-gold {
    background: linear-gradient(to right, #bf953f, #fcf6ba, #b38728);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .reveal-section {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .reveal-section.in-view {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('in-view');
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal-section').forEach(el => obs.observe(el));
</script>