---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    // Di Astro v6 dengan loader glob, post.id adalah slug-nya
    params: { slug: post.id }, 
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;

/** * FIX UTAMA: Di Astro v6, gunakan fungsi render(post) 
 * Ini yang bikin build kamu tadi error "post.render is not a function"
 */
const { Content } = (await render(post)) as { Content: any };

// Logic Reading Time (Aman)
const wordCount = post.body ? post.body.split(/\s+/).length : 0;
const calculatedReadingTime = Math.max(1, Math.ceil(wordCount / 200));

// Normalisasi data untuk BlogLayout
const blogProps = {
  title: post.data.title,
  description: post.data.description,
  // Kirim sebagai Date agar sesuai dengan BlogLayout
  pubDate: new Date(post.data.pubDate),
  // Fallback jika image kosong
  image: post.data.image?.url ?? '/og_default.webp',
  readingTime: post.data.readingTime ?? calculatedReadingTime
};
---

<BlogLayout {...blogProps}>
  <article class="prose prose-invert prose-gold max-w-none">
    <Content />
  </article>
</BlogLayout>