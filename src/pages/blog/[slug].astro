---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';
import type { CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post: CollectionEntry<'blog'>) => ({ // Tambahkan tipe di sini
    params: { slug: post.id }, 
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;

// Paksa tipe data ke any sebentar supaya bisa render tanpa merah
const { Content } = await (post as any).render();

// Logic Reading Time
const wordCount = post.body ? post.body.split(/\s+/).length : 0;
const calculatedReadingTime = Math.max(1, Math.ceil(wordCount / 200));

// Normalisasi data untuk BlogLayout
const blogProps = {
  title: post.data.title,
  description: post.data.description,
  // Pastikan pubDate dikonversi ke string agar aman dikirim ke Layout
  pubDate: new Date(post.data.pubDate),
  // Proteksi jika image undefined atau null
  image: post.data.image?.url ?? '/og-default.jpg',
  readingTime: post.data.readingTime ?? calculatedReadingTime
};
---

<BlogLayout {...blogProps}>
  <Content />
</BlogLayout>