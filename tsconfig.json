{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "astro:content": [".astro/types.d.ts"]
    },
    "jsx": "preserve",
    "jsxImportSource": "astro",
    "ignoreDeprecations": "6.0"
  },
  "exclude": ["dist", "node_modules"]
}